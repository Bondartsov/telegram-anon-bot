# Telegram Bot Configuration
# Copy this file to .env and fill in your values

# Required: Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Required: Target group ID (negative number, e.g. -1001234567890)
# Used as fallback. Active group is set dynamically via /set_topic command.
GROUP_ID=-1001234567890

# Required: Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=your_telegram_user_id

# Optional: Questions per hour per user (default: 10)
RATE_LIMIT=10

# Optional: Logging level (default: INFO)
LOG_LEVEL=INFO
